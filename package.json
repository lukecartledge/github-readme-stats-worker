{
  "name": "github-readme-stats-worker",
  "version": "0.1.0",
  "description": "Self-hosted GitHub readme stats cards on Cloudflare Workers",
  "type": "module",
  "main": "src/worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  },
  "dependencies": {
    "emoji-name-map": "^2.0.3",
    "github-username-regex": "^1.0.0",
    "word-wrap": "^1.2.5"
  },
  "engines": {
    "node": ">=20"
  }
}
